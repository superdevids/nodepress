# ============================================================
# NodePress - .dockerignore
# ============================================================
# Prevents unnecessary files from being sent to the Docker
# build context, reducing build time and image size.
# ============================================================

# Dependencies — ignore all nested node_modules
node_modules/**
**/node_modules/**

# Version control
.git/**
.gitignore
.gitattributes

# IDE / Editor
.vscode
.idea
*.swp
*.swo
*~

# Documentation (but keep README.md for build context)
*.md
!README.md
*.mdx

# Build output
dist/**
.next/**
coverage/**
.turbo/**
*.tsbuildinfo

# Environment files (contain secrets) — catch all variants
.env
.env.*
!.env.example

# Package manager
pnpm-lock.yaml
yarn.lock
package-lock.json

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs
storage/logs

# Temp
tmp
temp
