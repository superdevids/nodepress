{
  "name": "nodepressjs",
  "version": "1.0.0-beta.2",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "nodepressjs": "packages/cli/dist/index.js"
  },
  "files": [
    "packages/cli/dist/",
    "packages/core/dist/",
    "packages/db/dist/",
    "packages/plugin-sdk/dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superdevids/nodepress.git"
  },
  "homepage": "https://github.com/superdevids/nodepress#readme",
  "bugs": {
    "url": "https://github.com/superdevids/nodepress/issues"
  },
  "keywords": [
    "cms",
    "cms",
    "nestjs",
    "nextjs",
    "headless-cms",
    "typescript"
  ],
  "license": "MIT",
  "author": "NodePress Team",
  "description": "Modern CMS built with Node.js / TypeScript — NestJS, Next.js, Prisma, PostgreSQL (beta)",
  "scripts": {
    "start": "node start.js",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "npx prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:push": "npx prisma db push --schema=packages/db/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=packages/db/prisma/schema.prisma",
    "db:seed": "npx ts-node --project packages/db/tsconfig.json packages/db/src/seed.ts",
    "db:studio": "npx prisma studio --schema=packages/db/prisma/schema.prisma",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "quick-install": "node scripts/quick-install.js",
    "install:quick": "node scripts/quick-install.js",
    "wp-import": "node scripts/wordpress-migrate.js",
    "migrate:wordpress": "node scripts/wordpress-migrate.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@changesets/config": "^3.0.0",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "rimraf": "^5.0.0",
    "turbo": "^1.13.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "fast-xml-parser": "^5.9.3"
  }
}
