{
  "name": "nodepress",
  "version": "0.0.1",
  "private": true,
  "description": "WordPress-compatible CMS built with Node.js / TypeScript",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @nodepress/db db:generate",
    "db:push": "pnpm --filter @nodepress/db db:push",
    "db:migrate": "pnpm --filter @nodepress/db db:migrate",
    "db:seed": "pnpm --filter @nodepress/db db:seed",
    "db:studio": "pnpm --filter @nodepress/db db:studio",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "rimraf": "^5.0.0",
    "@changesets/config": "^3.0.0",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "turbo": "^1.13.0",
    "typescript": "^5.4.0"
  }
}
