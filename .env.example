# ============================================================
# NodePress - Environment Variables Example
# Modern CMS built with Node.js / TypeScript
# ============================================================
# Copy this file to .env and adjust values for your environment
#   cp .env.example .env
#
# IMPORTANT: All values marked as REQUIRED must be set before
# starting the application in production. Empty values cause
# the application to fail with a clear error at startup.
# ============================================================

# ============================================================
# SECTION 1: REQUIRED (Must be set for production)
# ============================================================

# JWT signing secret — generate with: openssl rand -base64 48
JWT_SECRET=

# JWT refresh token secret — generate with: openssl rand -base64 48
JWT_REFRESH_SECRET=

# Encryption key (32 hex characters = 128-bit AES)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ============================================================
# SECTION 2: DATABASE (PostgreSQL via PgBouncer)
# ============================================================

# Connection through PgBouncer (port 6432 — connection pooling)
# Used by application queries at runtime
DATABASE_URL=postgresql://nodepress:nodepress@localhost:6432/nodepress

# Direct connection to PostgreSQL (port 5432 — bypasses PgBouncer)
# Used by Prisma migrations and admin commands that need direct access
DATABASE_DIRECT_URL=postgresql://nodepress:nodepress@localhost:5432/nodepress

# ============================================================
# SECTION 3: REDIS (Cache & Queue / BullMQ)
# ============================================================

# Connection string for Redis — used for cache, sessions, BullMQ queues
REDIS_URL=redis://localhost:6379

# ============================================================
# SECTION 4: JWT (Token Expiry & Issuer)
# ============================================================

# Access token lifetime (default: 15 minutes)
JWT_EXPIRY=15m

# Refresh token lifetime (default: 7 days)
REFRESH_TOKEN_EXPIRY=7d

# JWT issuer claim
JWT_ISSUER=nodepress

# ============================================================
# SECTION 5: APPLICATION URLS
# ============================================================

# Base URL for the admin panel (frontend)
APP_URL=http://localhost:3000

# Base URL for the API server
API_URL=http://localhost:3001

# Next.js public API URL — used in browser-side code
# Must be accessible from end-user browsers
NEXT_PUBLIC_API_URL=http://localhost:3001

# CORS allowed origins (comma-separated)
# In production, restrict to your actual domains
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================
# SECTION 6: STORAGE (S3-compatible / MinIO)
# ============================================================

# S3 endpoint URL (MinIO in dev, AWS S3 / Cloudflare R2 in prod)
S3_ENDPOINT=http://localhost:9000

# S3 region (MinIO default: us-east-1)
S3_REGION=us-east-1

# S3 access key (MinIO root user in dev)
S3_ACCESS_KEY=nodepress

# S3 secret key (MinIO root password in dev)
S3_SECRET_KEY=nodepress123

# S3 bucket name for media uploads
S3_BUCKET=nodepress-media

# Public-facing URL for media files served from S3
# In dev: MinIO direct URL; in prod: CDN or bucket public URL
S3_PUBLIC_URL=http://localhost:9000/nodepress-media

# ============================================================
# SECTION 7: MAIL (Optional — Notifications)
# ============================================================

# Email provider: smtp | ses | sendgrid | mailgun
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@nodepress.local

# ============================================================
# SECTION 8: OPTIONAL — General
# ============================================================

# Application environment
NODE_ENV=development

# Enable debug mode (verbose logging, stack traces)
NODEPRESS_DEBUG=true

# Log level: debug | info | warn | error
LOG_LEVEL=debug

# Log file path
LOG_FILE=storage/logs/nodepress.log

# API server port
PORT=3001

# Maintenance mode — returns 503 for non-admin requests
# MAINTENANCE_ALLOWED_IPS: Comma-separated IPs that bypass
MAINTENANCE_MODE=false
MAINTENANCE_ALLOWED_IPS=

# ============================================================
# SECTION 9: OPTIONAL — Security Keys & Salts
# ============================================================
# Used for cookie encryption, nonce generation, and
# cryptographic operations. Generate unique values per
# installation using: openssl rand -base64 48
# AUTH_KEY=
# AUTH_SALT=
# SECURE_AUTH_KEY=
# SECURE_AUTH_SALT=
# LOGGED_IN_KEY=
# LOGGED_IN_SALT=
# NONCE_KEY=
# NONCE_SALT=
# SECRET_KEY=

# ============================================================
# SECTION 10: OPTIONAL — Content Security Policy
# ============================================================
# CSP_ENABLED=true
# CSP_REPORT_ONLY=false

# ============================================================
# SECTION 11: OPTIONAL — Password Policy
# ============================================================
# PASSWORD_MIN_LENGTH=8
# PASSWORD_REQUIRE_NUMBERS=true
# PASSWORD_REQUIRE_SYMBOLS=true
# PASSWORD_REQUIRE_UPPERCASE=true
# PASSWORD_HISTORY_SIZE=5
# PASSWORD_EXPIRY_DAYS=90

# ============================================================
# SECTION 12: OPTIONAL — Rate Limiting (Redis-backed)
# ============================================================
# RATE_LIMIT_TTL=60
# RATE_LIMIT_MAX=100
# RATE_LIMIT_LOGIN_MAX=5

# ============================================================
# SECTION 13: OPTIONAL — Plugin System
# ============================================================
# LOCKED_PLUGINS=seo,cache
# DISABLE_PLUGIN_AUTO_UPDATE=false
# PLUGIN_SANDBOX_MEMORY_LIMIT=128
# PLUGIN_SANDBOX_TIMEOUT=5000

# ============================================================
# SECTION 14: OPTIONAL — Two-Factor Authentication
# ============================================================
# TOTP_ISSUER=NodePress
# TOTP_ENFORCE_FOR_ROLES=ADMIN,SUPER_ADMIN

# ============================================================
# SECTION 15: OPTIONAL — Observability
# ============================================================
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
# METRICS_ENABLED=false
