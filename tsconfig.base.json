{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": false,
    "forceConsistentCasingInFileNames": true,

    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,

    "baseUrl": ".",
    "paths": {
      "@nodepressjs/core": ["./packages/core/src"],
      "@nodepressjs/core/*": ["./packages/core/src/*"],
      "@nodepressjs/db": ["./packages/db/src"],
      "@nodepressjs/db/*": ["./packages/db/src/*"],
      "@nodepressjs/plugin-sdk": ["./packages/plugin-sdk/src"],
      "@nodepressjs/plugin-sdk/*": ["./packages/plugin-sdk/src/*"],
      "@nodepressjs/ui": ["./packages/ui/src"],
      "@nodepressjs/ui/*": ["./packages/ui/src/*"],
      "@nodepressjs/editor": ["./packages/editor/src"],
      "@nodepressjs/editor/*": ["./packages/editor/src/*"],
      "@nodepressjs/cli": ["./packages/cli/src"],
      "@nodepressjs/cli/*": ["./packages/cli/src/*"],
      "@nodepressjs/config": ["./packages/config/src"],
      "@nodepressjs/config/*": ["./packages/config/src/*"],
      "@nodepressjs/testing": ["./packages/testing/src"],
      "@nodepressjs/testing/*": ["./packages/testing/src/*"]
    }
  },
  "exclude": ["node_modules", ".turbo", "dist", ".next", "*.tsbuildinfo"]
}
